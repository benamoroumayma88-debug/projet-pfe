@model InsuranceWeb.Models.User
@{
    ViewData["Title"] = "Edit User";
    var roles = ViewBag.Roles as List<InsuranceWeb.Models.Role> ?? new();
}

<div class="page-wrapper">
    <div class="page-header">
        <h1>&#x270F;&#xFE0F; Edit User</h1>
        <p class="subtitle">Modify account details for <strong>@Model.Username</strong></p>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert-banner alert-error-banner">
            <span>&#x26A0;&#xFE0F;</span> @ViewBag.Error
        </div>
    }

    <div class="grid-2">
        <!-- Edit form -->
        <div class="panel">
            <div class="panel-header">&#x1F464; Account Details</div>
            <div class="panel-body">
                <form method="post" asp-action="EditUser" asp-route-id="@Model.UserId">
                    @Html.AntiForgeryToken()

                    <div class="form-group-upload">
                        <label>Username</label>
                        <input type="text" name="username" class="form-control-upload" required value="@Model.Username" />
                    </div>

                    <div class="form-group-upload" style="margin-top: .75rem;">
                        <label>Email</label>
                        <input type="email" name="email" class="form-control-upload" required value="@Model.Email" />
                    </div>

                    <div class="form-group-upload" style="margin-top: .75rem;">
                        <label>Login</label>
                        <input type="text" name="login" class="form-control-upload" required value="@Model.Login" />
                    </div>

                    <div class="form-group-upload" style="margin-top: .75rem;">
                        <label>New Password <small style="color: var(--text-muted);">(leave blank to keep current)</small></label>
                        <input type="password" name="password" class="form-control-upload" minlength="6" placeholder="Enter new password" />
                    </div>

                    <div class="form-group-upload" style="margin-top: .75rem;">
                        <label>Role</label>
                        <select name="roleId" class="form-control-upload" required>
                            @foreach (var role in roles)
                            {
                                if (Model.RoleId == role.RoleId)
                                {
                                    <option value="@role.RoleId" selected>@role.RoleName — @role.Description</option>
                                }
                                else
                                {
                                    <option value="@role.RoleId">@role.RoleName — @role.Description</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group-upload" style="margin-top: .75rem;">
                        <label>Status</label>
                        <select name="isActive" class="form-control-upload">
                            @if (Model.IsActive)
                            {
                                <option value="true" selected>Active</option>
                                <option value="false">Inactive</option>
                            }
                            else
                            {
                                <option value="true">Active</option>
                                <option value="false" selected>Inactive</option>
                            }
                        </select>
                    </div>

                    <div style="margin-top: 1.25rem; display: flex; gap: .75rem;">
                        <button type="submit" class="btn-upload">&#x1F4BE; Save Changes</button>
                        <a asp-action="Index" class="btn-upload" style="background: var(--text-muted);">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Quick actions -->
        <div>
            <div class="panel">
                <div class="panel-header">&#x26A1; Quick Actions</div>
                <div class="panel-body">
                    <form method="post" asp-action="ResetPassword" asp-route-id="@Model.UserId">
                        @Html.AntiForgeryToken()
                        <div class="form-group-upload">
                            <label>Reset Password</label>
                            <input type="password" name="newPassword" class="form-control-upload" required
                                   minlength="6" placeholder="New password (min 6 chars)" />
                        </div>
                        <button type="submit" class="btn-upload" style="margin-top: .75rem; background: var(--warning);">
                            &#x1F510; Reset Password
                        </button>
                    </form>
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">&#x2139;&#xFE0F; Account Info</div>
                <div class="panel-body">
                    <div class="info-row"><span class="info-label">User ID</span><span>@Model.UserId</span></div>
                    <div class="info-row"><span class="info-label">Created</span><span>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span></div>
                    <div class="info-row"><span class="info-label">Updated</span><span>@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span></div>
                    <div class="info-row"><span class="info-label">Current Role</span><span>@(Model.Role?.RoleName ?? "None")</span></div>
                    <div class="info-row">
                        <span class="info-label">Status</span>
                        <span>
                            @if (Model.IsActive)
                            {
                                <span class="badge-risk badge-low">Active</span>
                            }
                            else
                            {
                                <span class="badge-risk badge-medium">Inactive</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
