@model List<InsuranceWeb.Models.User>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-wrapper">
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1>&#x1F6E0;&#xFE0F; Admin Dashboard</h1>
                <p class="subtitle">Manage users, roles, and account settings</p>
            </div>
            <a asp-action="CreateUser" class="btn-upload">&#x2795; New User</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-banner alert-success-banner">
            <span>&#x2705;</span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-banner alert-error-banner">
            <span>&#x26A0;&#xFE0F;</span> @TempData["Error"]
        </div>
    }

    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-value text-primary">@ViewBag.TotalUsers</div>
            <div class="kpi-label">Total Users</div>
        </div>
        <div class="kpi-card kpi-success">
            <div class="kpi-value text-success">@ViewBag.ActiveUsers</div>
            <div class="kpi-label">Active</div>
        </div>
        <div class="kpi-card kpi-danger">
            <div class="kpi-value text-danger">@ViewBag.InactiveUsers</div>
            <div class="kpi-label">Inactive</div>
        </div>
    </div>

    <!-- Audit Log Banner -->
    @{
        var unresolvedAlerts = (int)(ViewBag.UnresolvedAlerts ?? 0);
    }
    <a asp-action="AuditLog" class="audit-log-banner @(unresolvedAlerts > 0 ? "audit-banner-alert" : "")">
        <div class="audit-banner-icon">
            &#x1F6E1;&#xFE0F;
            @if (unresolvedAlerts > 0)
            {
                <span class="audit-banner-dot">@unresolvedAlerts</span>
            }
        </div>
        <div class="audit-banner-text">
            <span class="audit-banner-title">Audit Log</span>
            <span class="audit-banner-subtitle">
                @if (unresolvedAlerts > 0)
                {
                    <strong style="color:#fca5a5;">@unresolvedAlerts unresolved alert@(unresolvedAlerts != 1 ? "s" : "")</strong>
                    <span> — View security events &amp; take action &rarr;</span>
                }
                else
                {
                    <span>No alerts — View login history &amp; security events &rarr;</span>
                }
            </span>
        </div>
        <div class="audit-banner-arrow">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </div>
    </a>

    <div class="grid-2">
        <!-- Users Table -->
        <div class="panel" style="grid-column: 1 / -1;">
            <div class="panel-header">&#x1F465; Users</div>
            <div class="panel-body p-0">
                <div style="overflow-x: auto;">
                    <table class="table-bi">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Login</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.UserId</td>
                                    <td><strong>@user.Username</strong></td>
                                    <td><code>@user.Login</code></td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="role-badge role-@user.Role?.RoleName?.ToLower().Replace(" ", "-")">
                                            @(user.Role?.RoleName ?? "No Role")
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge-risk badge-low">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-risk badge-medium">Inactive</span>
                                        }
                                    </td>
                                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <div style="display: flex; gap: .4rem;">
                                            <a asp-action="EditUser" asp-route-id="@user.UserId"
                                               class="btn-action btn-edit" title="Edit">&#x270F;&#xFE0F;</a>
                                            <form method="post" asp-action="ToggleActive" asp-route-id="@user.UserId"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-action @(user.IsActive ? "btn-deactivate" : "btn-activate")"
                                                        title="@(user.IsActive ? "Deactivate" : "Activate")">
                                                    @(user.IsActive ? "🔒" : "🔓")
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
