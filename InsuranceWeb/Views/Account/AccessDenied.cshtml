@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-wrapper">
    <div class="panel" style="text-align: center; padding: 3rem;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🔒</div>
        <h1 style="color: var(--danger); margin-bottom: 0.5rem;">Access Denied</h1>
        <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem;">
            You don't have permission to access this page.
        </p>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">
            If you believe this is a mistake, please contact your administrator.
        </p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary" style="padding: 0.75rem 1.5rem; text-decoration: none; background: var(--accent); color: white; border-radius: var(--radius); font-weight: 600;">
            Return to Dashboard
        </a>
    </div>
</div>
