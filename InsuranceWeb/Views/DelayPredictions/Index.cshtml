@model InsuranceWeb.Models.DelayPredictionsViewModel
@{
    ViewData["Title"] = "Delay Predictions";
}

<div class="page-header">
    <h1>&#x23F1;&#xFE0F; Delay Predictions Dashboard</h1>
    <p class="subtitle">Identify claims at risk of processing delays and allocate resources proactively</p>
    @if (!string.IsNullOrEmpty(Model.SelectedRunId))
    {
        <span class="run-badge">Run: @Model.SelectedRunId</span>
    }
</div>

<!-- ═══ KPI Cards ═══ -->
@if (Model.Summary != null)
{
    var s = Model.Summary;
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-value text-primary">@s.TotalActiveClaims.ToString("N0")</div>
            <div class="kpi-label">Claims Scored</div>
        </div>
        <div class="kpi-card kpi-danger">
            <div class="kpi-value text-danger">@s.PredictedDelayedCount</div>
            <div class="kpi-label">Predicted Delayed</div>
        </div>
        <div class="kpi-card kpi-warning">
            <div class="kpi-value text-warning">@s.HighRiskCount</div>
            <div class="kpi-label">High Risk</div>
        </div>
        <div class="kpi-card kpi-info">
            <div class="kpi-value text-info">@s.RecommendedStaff</div>
            <div class="kpi-label">Recommended Staff</div>
        </div>
        <div class="kpi-card kpi-success">
            <div class="kpi-value text-success">@s.AvgDelayDaysPerClaim.ToString("F1")</div>
            <div class="kpi-label">Avg Delay Days</div>
        </div>
        <div class="kpi-card kpi-critical">
            <div class="kpi-value text-critical">@s.EstimatedCostImpactTnd.ToString("N0")</div>
            <div class="kpi-label">Cost Impact (TND)</div>
        </div>
    </div>

    <!-- ═══ Risk Distribution & On-Time vs Delayed ═══ -->
    <div class="grid-2">
        <div class="panel">
            <div class="panel-header">&#x1F4CA; Risk Distribution</div>
            <div class="panel-body">
                <div class="chart-container">
                    <canvas id="riskDoughnut"></canvas>
                </div>
            </div>
        </div>
        <div class="panel">
            <div class="panel-header">&#x2705; On-Time vs Delayed</div>
            <div class="panel-body">
                @{
                    long onTime = s.TotalActiveClaims - s.PredictedDelayedCount;
                }
                <div style="margin-bottom:.75rem;display:flex;justify-content:space-between;font-size:.85rem;">
                    <span><span class="badge-risk badge-low">On-Time</span> @onTime claims</span>
                    <span><span class="badge-risk badge-high">Delayed</span> @s.PredictedDelayedCount claims</span>
                </div>
                <div class="risk-bar" style="height:36px;">
                    <div class="segment seg-low" style="flex:@onTime;">@((s.TotalActiveClaims > 0 ? (double)onTime / s.TotalActiveClaims * 100 : 0).ToString("F1"))%</div>
                    <div class="segment seg-high" style="flex:@s.PredictedDelayedCount;">@((s.TotalActiveClaims > 0 ? (double)s.PredictedDelayedCount / s.TotalActiveClaims * 100 : 0).ToString("F1"))%</div>
                </div>
                <div style="margin-top:1.5rem;">
                    <div class="chart-container">
                        <canvas id="delayedBar"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══ Filters ═══ -->
<form method="get" class="filter-bar">
    <div class="form-group">
        <label>Prediction Run</label>
        <select name="runId">
            @foreach (var run in Model.AvailableRunIds)
            {
                <option value="@run" selected="@(run == Model.SelectedRunId)">@run</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label>Risk Level</label>
        <select name="riskLevel">
            <option value="">All</option>
            <option value="High" selected="@("High" == Model.SelectedRiskLevel)">High</option>
            <option value="Medium" selected="@("Medium" == Model.SelectedRiskLevel)">Medium</option>
            <option value="Low" selected="@("Low" == Model.SelectedRiskLevel)">Low</option>
        </select>
    </div>
    <div class="form-group">
        <label>Claim ID</label>
        <input type="text" name="claimId" value="@Model.SearchClaimId" placeholder="Search..." />
    </div>
    <div class="form-group" style="justify-content:end;">
        <label>&nbsp;</label>
        <label style="font-size:.85rem;text-transform:none;font-weight:500;cursor:pointer;">
            <input type="checkbox" name="delayedOnly" value="true" @(Model.DelayedOnly ? "checked" : "") style="margin-right:.3rem;" />
            Delayed only
        </label>
    </div>
    <button type="submit" class="btn-apply">Apply Filters</button>
</form>

<!-- ═══ Data Table ═══ -->
<div class="panel">
    <div class="panel-header">
        &#x1F4CB; Claim Predictions
        <span style="margin-left:auto;font-weight:400;font-size:.82rem;color:var(--text-muted);">
            Showing @((Model.PageNumber - 1) * Model.PageSize + 1)&ndash;@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))
            of @Model.TotalCount claims
        </span>
    </div>
    <div class="panel-body p-0" style="overflow-x:auto;">
        <table class="table-bi">
            <thead>
                <tr>
                    <th>Claim ID</th>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Coverage</th>
                    <th>Severity</th>
                    <th>SLA (days)</th>
                    <th>Delay Prob.</th>
                    <th>Risk</th>
                    <th>Delayed?</th>
                    <th>Est. Delay Days</th>
                    <th>Cost Impact (TND)</th>
                    <th>Month</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Claims)
                {
                    <tr>
                        <td style="font-family:monospace;font-size:.82rem;">@c.ClaimId</td>
                        <td>@c.StatutSinistreClaim</td>
                        <td>@c.TypeSinistreClaim</td>
                        <td>@c.TypeCouverture</td>
                        <td>
                            @{
                                var sevClass = c.ClaimSeverityBucket?.ToLower() switch { "high" => "high", "medium" => "med", _ => "low" };
                            }
                            <span class="badge-severity @sevClass">@c.ClaimSeverityBucket</span>
                        </td>
                        <td class="text-center">@c.SlaJours</td>
                        <td class="text-center" style="font-weight:600;">@(c.DelayProbability.ToString("P1"))</td>
                        <td class="text-center">
                            @{
                                var riskClass = c.RiskLevel?.ToLower() switch { "high" => "badge-high", "medium" => "badge-medium", _ => "badge-low" };
                            }
                            <span class="badge-risk @riskClass">@c.RiskLevel</span>
                        </td>
                        <td class="text-center">
                            <span class="badge-risk @(c.PredictedDelayed ? "badge-yes" : "badge-no")">@(c.PredictedDelayed ? "Yes" : "No")</span>
                        </td>
                        <td class="text-center">@(c.PredictedDelayed ? c.PredictedDelayDays?.ToString("F0") ?? "—" : "—")</td>
                        <td class="text-right">@(c.EstimatedCostImpactClaim.HasValue ? c.EstimatedCostImpactClaim.Value.ToString("N2") : "—")</td>
                        <td>@c.PredictionMonth</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ═══ Pagination ═══ -->
@if (Model.TotalPages > 1)
{
    <div class="pagination-bar">
        <span>Page @Model.PageNumber of @Model.TotalPages</span>
        <div>
            @if (Model.HasPreviousPage)
            {
                <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                   asp-route-claimId="@Model.SearchClaimId" asp-route-delayedOnly="@Model.DelayedOnly"
                   asp-route-page="@(Model.PageNumber - 1)">&laquo; Previous</a>
            }
            else
            {
                <span class="disabled">&laquo; Previous</span>
            }

            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
            {
                if (i == Model.PageNumber)
                {
                    <strong style="padding:.3rem .65rem;">@i</strong>
                }
                else
                {
                    <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                       asp-route-claimId="@Model.SearchClaimId" asp-route-delayedOnly="@Model.DelayedOnly"
                       asp-route-page="@i">@i</a>
                }
            }

            @if (Model.HasNextPage)
            {
                <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                   asp-route-claimId="@Model.SearchClaimId" asp-route-delayedOnly="@Model.DelayedOnly"
                   asp-route-page="@(Model.PageNumber + 1)">Next &raquo;</a>
            }
            else
            {
                <span class="disabled">Next &raquo;</span>
            }
        </div>
    </div>
}

@section Scripts {
    @if (Model.Summary != null)
    {
        var s = Model.Summary;
        <script>
            (function () {
                // Doughnut: Risk distribution
                new Chart(document.getElementById('riskDoughnut').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['High', 'Medium', 'Low'],
                        datasets: [{
                            data: [@s.HighRiskCount, @s.MediumRiskCount, @s.LowRiskCount],
                            backgroundColor: ['#ef4444', '#f59e0b', '#10b981'],
                            borderWidth: 0,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '60%',
                        plugins: {
                            legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true } }
                        }
                    }
                });

                // Bar: On-Time vs Delayed detail
                new Chart(document.getElementById('delayedBar').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: ['On-Time', 'Delayed'],
                        datasets: [{
                            data: [@(s.TotalActiveClaims - s.PredictedDelayedCount), @s.PredictedDelayedCount],
                            backgroundColor: ['#10b981', '#ef4444'],
                            borderRadius: 6,
                            barThickness: 48
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, title: { display: true, text: 'Claims' } } }
                    }
                });
            })();
        </script>
    }
}
