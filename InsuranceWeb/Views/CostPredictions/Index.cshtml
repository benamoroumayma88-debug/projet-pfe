@model InsuranceWeb.Models.CostDashboardViewModel
@{
    ViewData["Title"] = "Cost Predictions";
}

<div class="page-header">
    <h1>&#x1F4B0; Cost Predictions Dashboard</h1>
    <p class="subtitle">Predict claim settlement costs and identify high-cost claims for budget planning</p>
    @if (!string.IsNullOrEmpty(Model.SelectedRunId))
    {
        <span class="run-badge">Run: @Model.SelectedRunId</span>
    }
</div>

<!-- ═══ KPI Cards ═══ -->
@if (Model.Summary != null)
{
    var s = Model.Summary;
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-value text-primary">@s.TotalActiveClaims.ToString("N0")</div>
            <div class="kpi-label">Active Claims</div>
        </div>
        <div class="kpi-card kpi-danger">
            <div class="kpi-value text-danger">@s.TotalPredictedCost.ToString("N0")</div>
            <div class="kpi-label">Total Predicted Cost (TND)</div>
        </div>
        <div class="kpi-card kpi-warning">
            <div class="kpi-value text-warning">@s.AverageCostPerClaim.ToString("N0")</div>
            <div class="kpi-label">Avg Cost / Claim (TND)</div>
        </div>
        <div class="kpi-card kpi-critical">
            <div class="kpi-value text-critical">@((s.HighCostRate * 100).ToString("F1"))%</div>
            <div class="kpi-label">High Cost Rate</div>
        </div>
        <div class="kpi-card kpi-info">
            <div class="kpi-value text-info">@((s.BudgetDeviationRisk * 100).ToString("F1"))%</div>
            <div class="kpi-label">Budget Deviation Risk</div>
        </div>
        <div class="kpi-card kpi-success">
            <div class="kpi-value text-success">@s.CostThresholdTnd.ToString("N0")</div>
            <div class="kpi-label">High-Cost Threshold (TND)</div>
        </div>
    </div>

    <!-- ═══ Power BI Dashboard ═══ -->
    <div class="panel">
        <div class="panel-header">&#x1F4B0; Cost Predictions Report</div>
        <div class="panel-body p-0">
            <iframe title="Power BI Cost Report"
                    src="https://app.powerbi.com/reportEmbed?reportId=ad2898aa-7ff2-4fbe-b0fb-dd00ad991814&autoAuth=true&ctid=119689b1-4b51-43b0-9c27-34e6c9279d98"
                    style="width:100%;height:780px;border:none;display:block;"
                    allowfullscreen="true">
            </iframe>
        </div>
    </div>
}

<!-- ═══ Filters ═══ -->
<form method="get" class="filter-bar">
    <div class="form-group">
        <label>Prediction Run</label>
        <select name="runId">
            @foreach (var run in Model.AvailableRunIds)
            {
                <option value="@run" selected="@(run == Model.SelectedRunId)">@run</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label>Risk Level</label>
        <select name="riskLevel">
            <option value="">All</option>
            <option value="High" selected="@("High" == Model.SelectedRiskLevel)">High</option>
            <option value="Medium" selected="@("Medium" == Model.SelectedRiskLevel)">Medium</option>
            <option value="Low" selected="@("Low" == Model.SelectedRiskLevel)">Low</option>
        </select>
    </div>
    <div class="form-group">
        <label>Claim ID</label>
        <input type="text" name="claimId" value="@Model.SearchClaimId" placeholder="Search..." />
    </div>
    <button type="submit" class="btn-apply">Apply Filters</button>
</form>

<!-- ═══ Data Table ═══ -->
<div class="panel">
    <div class="panel-header">
        &#x1F4CB; Cost Predictions
        <span style="margin-left:auto;font-weight:400;font-size:.82rem;color:var(--text-muted);">
            Showing @((Model.PageNumber - 1) * Model.PageSize + 1)&ndash;@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))
            of @Model.TotalCount claims
        </span>
    </div>
    <div class="panel-body p-0" style="overflow-x:auto;">
        <table class="table-bi">
            <thead>
                <tr>
                    <th>Claim ID</th>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Severity</th>
                    <th>Predicted Cost (TND)</th>
                    <th>Cost Risk</th>
                    <th>Month</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Claims)
                {
                    <tr>
                        <td style="font-family:monospace;font-size:.82rem;">@c.ClaimId</td>
                        <td>@c.StatutSinistreClaim</td>
                        <td>@c.TypeSinistreClaim</td>
                        <td>
                            @{
                                var sevClass = c.ClaimSeverityBucket?.ToLower() switch { "high" => "high", "medium" => "med", _ => "low" };
                            }
                            <span class="badge-severity @sevClass">@c.ClaimSeverityBucket</span>
                        </td>
                        <td class="text-right" style="font-weight:600;">@c.PredictedCost.ToString("N2")</td>
                        <td class="text-center">
                            @{
                                var riskClass = c.CostRiskLevel?.ToLower() switch { "high" => "badge-high", "medium" => "badge-medium", _ => "badge-low" };
                            }
                            <span class="badge-risk @riskClass">@c.CostRiskLevel</span>
                        </td>
                        <td>@c.PredictionMonth</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ═══ Pagination ═══ -->
@if (Model.TotalPages > 1)
{
    <div class="pagination-bar">
        <span>Page @Model.PageNumber of @Model.TotalPages</span>
        <div>
            @if (Model.HasPreviousPage)
            {
                <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                   asp-route-claimId="@Model.SearchClaimId" asp-route-page="@(Model.PageNumber - 1)">&laquo; Previous</a>
            }
            else
            {
                <span class="disabled">&laquo; Previous</span>
            }

            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
            {
                if (i == Model.PageNumber)
                {
                    <strong style="padding:.3rem .65rem;">@i</strong>
                }
                else
                {
                    <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                       asp-route-claimId="@Model.SearchClaimId" asp-route-page="@i">@i</a>
                }
            }

            @if (Model.HasNextPage)
            {
                <a asp-action="Index" asp-route-runId="@Model.SelectedRunId" asp-route-riskLevel="@Model.SelectedRiskLevel"
                   asp-route-claimId="@Model.SearchClaimId" asp-route-page="@(Model.PageNumber + 1)">Next &raquo;</a>
            }
            else
            {
                <span class="disabled">Next &raquo;</span>
            }
        </div>
    </div>
}

